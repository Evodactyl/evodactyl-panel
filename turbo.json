{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "globalEnv": ["NODE_ENV", "APP_ENV", "APP_DEBUG", "APP_KEY", "DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "@evodactyl/db#generate"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"]
    },
    "@evodactyl/db#generate": {
      "cache": true,
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["src/generated/**", "node_modules/.prisma/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@evodactyl/db#generate"]
    },
    "preview": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build", "@evodactyl/web#build", "@evodactyl/db#generate"]
    },
    "test": {
      "dependsOn": ["^build", "@evodactyl/db#generate"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["@evodactyl/db#generate"],
      "outputs": []
    }
  }
}
