{
  "name": "evodactyl-panel",
  "private": true,
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22",
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@evodactyl/api",
    "preview": "turbo run preview --filter=@evodactyl/api",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "docs": "bun run --filter=@evodactyl/docs dev",
    "docs:dev": "bun run --filter=@evodactyl/docs dev",
    "docs:build": "bun run --filter=@evodactyl/docs build",
    "docs:preview": "bun run --filter=@evodactyl/docs preview",
    "docs:typecheck": "bun run --filter=@evodactyl/docs typecheck",
    "db:generate": "bun run --filter=@evodactyl/db generate",
    "db:migrate": "bun run --filter=@evodactyl/db migrate",
    "db:studio": "bun run --filter=@evodactyl/db studio"
  },
  "overrides": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  },
  "resolutions": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "turbo": "^2.3.0",
    "typescript": "~5.7.0"
  }
}
